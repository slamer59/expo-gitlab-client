{
  "name": "expo-gitlab-client",
  "main": "expo-router/entry",
  "version": "1.2.1",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --no-watchman --passWithNoTests",
    "build:android": "eas build --platform android",
    "build:android-production-apk": "eas build --platform android --profile production-apk",
    "build:android-development": "eas build --platform android --profile development",
    "build:android-preview": "eas build --platform android --profile preview",
    "build:android-preview-local": "eas build --platform android --local --profile preview",
    "build:android-development-local": "eas build --platform android --local --profile development",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "release": "semantic-release",
    "lint": "eslint .",
    "prepare": "husky",
    "push:android": "adb install $(find . -name \"*.apk\" -type f -print0 | xargs -0 ls -t | head -n 1)",
    "maestro:all": "maestro test .maestro/all.yaml",
    "maestro:studio": "maestro studio",
    "ts-check": "tsc --noEmit",
    "licences": "bunx generate-license-file --input ./package.json --output ./third-party-licenses.txt --overwrite",
    "push-google-service-secret": "eas secret:create --scope project --name GOOGLE_SERVICES_JSON --type file --value ./google-services.json",
    "firebase:env": "source ./firebase-functions/gitlab-events/functions/venv/bin/activate",
    "firebase:build": "npm run firebase:env && cd ./firebase-functions/gitlab-events/functions && uv pip install .",
    "firebase:emulators": "npm run firebase:env  && cd ./firebase-functions/gitlab-events && firebase emulators:start",
    "firebase:deploy-functions": "npm run firebase:env  && cd ./firebase-functions/gitlab-events && firebase deploy --only functions",
    "commit": "git-cz"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.js"],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|expo|@expo|zustand|@react-native-async-storage|expo-modules-core|react-native-css-interop|expo-font|@rn-primitives)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^lib/(.*)$": "<rootDir>/lib/$1"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.0",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@rn-primitives/accordion": "^1.0.3",
    "@rn-primitives/alert-dialog": "^1.0.4",
    "@rn-primitives/avatar": "~1.4.0",
    "@rn-primitives/checkbox": "^1.0.3",
    "@rn-primitives/collapsible": "^1.0.3",
    "@rn-primitives/dialog": "^1.0.4",
    "@rn-primitives/dropdown-menu": "^1.0.3",
    "@rn-primitives/label": "^1.0.4",
    "@rn-primitives/portal": "~1.4.0",
    "@rn-primitives/progress": "~1.4.0",
    "@rn-primitives/select": "^1.0.3",
    "@rn-primitives/separator": "^1.0.4",
    "@rn-primitives/slot": "^1.0.4",
    "@rn-primitives/switch": "^1.0.3",
    "@rn-primitives/tabs": "^1.0.4",
    "@rn-primitives/toggle": "^1.0.4",
    "@rn-primitives/toggle-group": "^1.0.4",
    "@rn-primitives/tooltip": "~1.4.0",
    "@rn-primitives/types": "^1.0.4",
    "@tanstack/react-query": "^5.50.1",
    "@tanstack/react-query-devtools": "^5.50.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.0",
    "ajv": "^8.17.1",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.1",
    "expo": "~56.0.0",
    "expo-application": "~56.0.0",
    "expo-background-fetch": "~56.0.0",
    "expo-build-properties": "~56.0.0",
    "expo-clipboard": "~56.0.0",
    "expo-constants": "~56.0.0",
    "expo-dev-client": "~56.0.0",
    "expo-device": "~56.0.0",
    "expo-document-picker": "~56.0.0",
    "expo-dom": "^27.0.2",
    "expo-file-system": "~56.0.0",
    "expo-font": "~56.0.0",
    "expo-image": "~56.0.0",
    "expo-image-picker": "~56.0.0",
    "expo-linking": "~56.0.0",
    "expo-localization": "~56.0.0",
    "expo-navigation-bar": "~56.0.0",
    "expo-notifications": "~56.0.0",
    "expo-router": "~56.2.0",
    "expo-secure-store": "~56.0.0",
    "expo-sharing": "~56.0.0",
    "expo-splash-screen": "~56.0.0",
    "expo-status-bar": "~56.0.0",
    "expo-system-ui": "~56.0.0",
    "expo-task-manager": "~56.0.0",
    "expo-updates": "~56.0.0",
    "expo-web-browser": "~56.0.0",
    "firebase": "^12.0.0",
    "lucide-react-native": "^1.0.0",
    "nativewind": "^4.0.33",
    "posthog-react-native": "^4.0.0",
    "prettier": "^3.3.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.53.0",
    "react-native": "0.85.0",
    "react-native-cn-quill": "^0.7.18",
    "react-native-file-type": "^1.0.0",
    "react-native-gesture-handler": "~3.0.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-mime-types": "^2.5.0",
    "react-native-reanimated": "~4.3.0",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "15.15.4",
    "react-native-syntax-highlighter": "^2.1.0",
    "react-native-vector-icons": "^10.1.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.1",
    "react-syntax-highlighter": "^16.0.0",
    "semantic-release": "^25.0.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.0-rc.2"
  },
  "devDependencies": {
    "@babel/core": "^8.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.0.0",
    "@semantic-release/npm": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.0",
    "eslint-config-expo": "~56.0.0",
    "git-format-staged": "^4.0.0",
    "husky": "^9.1.5",
    "jest": "~30.4.0",
    "jest-expo": "~56.0.0",
    "metro": "^0.84.0",
    "metro-config": "^0.84.0",
    "metro-resolver": "^0.84.0",
    "react-test-renderer": "19.2.7",
    "typescript": "^6.0.0"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/thomas.pedot1/expo-gitlab-client.git"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-cn-quill",
          "react-native-syntax-highlighter",
          "@radix-ui/react-progress",
          "@radix-ui/react-tooltip",
          "@tanstack/react-query-devtools",
          "@testing-library/jest-native",
          "ajv",
          "eslint-config-prettier",
          "eslint-plugin-prettier",
          "expo-dom",
          "firebase",
          "prettier",
          "react-native-file-type",
          "react-native-mime-types",
          "react-native-vector-icons",
          "react-syntax-highlighter",
          "semantic-release",
          "tailwindcss-animate"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "overrides": {
    "metro": "^0.84.0",
    "metro-config": "^0.84.0",
    "metro-resolver": "^0.84.0"
  }
}
