{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>slamer59/renovate-config"],
  "packageRules": [
    {
      "matchPackagePatterns": ["^expo", "^react-native", "^@react-native"],
      "groupName": "Expo + React Native",
      "automerge": false
    },
    {
      "matchPackagePatterns": ["^@remix-run/"],
      "groupName": "@remix-run"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.gitlab-ci\\.yml$"],
      "matchStrings": [
        "BUN_VERSION: \"(?<currentValue>[^\"]+)\"",
        "NODE_VERSION: \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "oven-sh/bun",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ]
}
