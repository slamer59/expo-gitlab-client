{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>slamer59/renovate-config"],
  "packageRules": [
    {
      "groupName": "Expo + React Native",
      "automerge": false,
      "matchPackageNames": [
        "/^expo/",
        "/^react-native/",
        "/^@react-native/"
      ]
    },
    {
      "groupName": "@remix-run",
      "matchPackageNames": [
        "/^@remix-run//"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.gitlab-ci\\.yml$/"
      ],
      "matchStrings": [
        "BUN_VERSION: \"(?<currentValue>[^\"]+)\"",
        "NODE_VERSION: \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "oven-sh/bun",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ]
}
